# .pubignore REPLACES .gitignore in this directory for `pub publish`, so it must
# repeat the build/tooling excludes — otherwise build artifacts leak into the
# published archive (a 44 MB .dill got in when this only listed DESIGN.md).
# Unanchored patterns also cover example/ subdirectories.

.dart_tool/
build/
.flutter-plugins-dependencies
coverage/
pubspec.lock
**/doc/api/
*.iml
.idea/

# Dev/test harness — kept in the repo for CI and local runs, but a consumer of
# the package never runs it. The published archive is what people import and
# read: lib/, the example DEMO (example/lib/main.dart), and the docs.
test/
example/integration_test/
example/test_driver/
example/test/

# Internal design notes — kept in git, not shipped to pub.dev.
DESIGN.md
# Benchmark charts: they illustrate BENCHMARK.md on GitHub, but pub.dev doesn't
# render that file, so shipping them would be dead weight. (doc/demo.png stays —
# the README hero uses it.)
doc/cover.png
doc/bench-size.png
doc/bench-time.png
